<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="adnseq.MainController"
            fitToWidth="true">

    <content>
        <BorderPane style="-fx-background-color: #f4f4f4;">

            <!-- ZONA DE TITLU SUS -->
            <top>
                <VBox alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #1e1e2f;">
                    <Label text="Simulare Evoluție Genetică ADN"
                           style="-fx-font-size: 24; -fx-text-fill: white; -fx-font-weight: bold;" />
                    <Label text="Algoritm genetic aplicat pe secvențe ADN (A, C, G, T)"
                           style="-fx-text-fill: #dddddd;" />
                </VBox>
            </top>

            <!-- STÂNGA: PARAMETRI / INPUT -->
            <left>
                <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #ffffff;"
                      prefWidth="260">

                    <Label text="Parametri simulare"
                           style="-fx-font-size: 16; -fx-font-weight: bold;" />

                    <Label text="Secvență țintă:" />
                    <TextField fx:id="targetField"
                               promptText="ex: ATGCGA" />

                    <Label text="Dimensiune populație:" />
                    <TextField fx:id="popSizeField"
                               promptText="ex: 20" />

                    <Label text="Rată de mutație:" />
                    <TextField fx:id="mutationField"
                               promptText="ex: 0.05" />

                    <Label text="Număr maxim de generații:" />
                    <TextField fx:id="maxGenerationsField"
                               promptText="ex: 500" />

                    <Button text="Start Evoluție"
                            fx:id="startButton"
                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 6 10 6 10;"/>

                </VBox>
            </left>

            <!-- CENTRU: rezultate + grafic -->
            <center>
                <VBox spacing="10" style="-fx-padding: 15;">

                    <!-- Rezultate text -->
                    <VBox spacing="5" style="-fx-background-color: #ffffff; -fx-padding: 10; -fx-border-color: #dddddd;">
                        <Label text="Rezultate simulare"
                               style="-fx-font-size: 16; -fx-font-weight: bold;" />

                        <Label fx:id="generationLabel"
                               text="Generații rulate: -"
                               style="-fx-font-size: 14;" />

                        <Label fx:id="bestLabel"
                               text="Cel mai bun individ: -"
                               style="-fx-font-size: 14;" />

                        <Label fx:id="fitnessLabel"
                               text="Fitness: -"
                               style="-fx-font-size: 14;" />

                        <Separator />

                        <Label text="Secvența cea mai bună (colorată):"
                               style="-fx-font-weight: bold;" />
                        <TextFlow fx:id="bestSequenceFlow"
                                  style="-fx-background-color: #f0f0f0; -fx-padding: 5;" />
                    </VBox>

                    <!-- Grafic -->
                    <VBox spacing="5"
                          style="-fx-background-color: #ffffff; -fx-padding: 10; -fx-border-color: #dddddd;">
                        <Label text="Evoluția fitness-ului (Best vs Mediu)"
                               style="-fx-font-size: 16; -fx-font-weight: bold;" />
                        <LineChart fx:id="fitnessChart" prefHeight="250" prefWidth="600">
                            <xAxis>
                                <NumberAxis label="Generație" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Fitness" />
                            </yAxis>
                        </LineChart>
                    </VBox>

                </VBox>
            </center>

            <!-- JOS: istoric + explicații -->
            <bottom>
                <VBox spacing="10" style="-fx-padding: 10;">

                    <HBox spacing="10">
                        <!-- Istoric evoluție -->
                        <VBox spacing="5"
                              style="-fx-background-color: #ffffff; -fx-padding: 10; -fx-border-color: #dddddd;"
                              VBox.vgrow="ALWAYS">
                            <Label text="Istoric evoluție (Best / Mediu)"
                                   style="-fx-font-size: 14; -fx-font-weight: bold;" />
                            <TextArea fx:id="logArea"
                                      prefRowCount="6"
                                      editable="false"
                                      wrapText="true" />
                        </VBox>

                        <!-- Explicații -->
                        <VBox spacing="5"
                              style="-fx-background-color: #ffffff; -fx-padding: 10; -fx-border-color: #dddddd;"
                              VBox.vgrow="ALWAYS">

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Explicații (biologie + algoritm genetic)"
                                       style="-fx-font-size: 14; -fx-font-weight: bold;" />
                                <Button fx:id="openInfoWindowButton"
                                        text="Deschide în fereastră separată"
                                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 4 8 4 8;"/>
                            </HBox>

                            <TextArea fx:id="infoArea"
                                      prefRowCount="6"
                                      editable="false"
                                      wrapText="true" />
                        </VBox>
                    </HBox>

                </VBox>
            </bottom>

        </BorderPane>
    </content>
</ScrollPane>
